@model QuizCompetitionManager.Models.Team

@{
    ViewData["Title"] = "Редакция на име на отбор";
}

<h2 class="mb-3">Редакция на име на отбор</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="EditName" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Ново име на отбора</label>
                <input name="name" class="form-control" maxlength="80" value="@Model.Name" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Запази</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
