@model QuizCompetitionManager.Models.Team

@{
    ViewData["Title"] = "Моят отбор";
}

<h2 class="mb-3">Моят отбор</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title mb-0">@Model.Name</h5>
        <div class="text-muted">Членове: @Model.Members.Count</div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Добави член</div>
            <div class="card-body">
                <form asp-action="AddMember" method="post" class="d-flex gap-2">
                    <input name="fullName" class="form-control" placeholder="Име и фамилия" maxlength="80" />
                    <button class="btn btn-primary" type="submit">Добави</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Списък с членове</div>
            <div class="card-body">
                @if (!Model.Members.Any())
                {
                    <div class="text-muted">Няма добавени членове.</div>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var m in Model.Members.OrderBy(x => x.FullName))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@m.FullName</span>

                                <form asp-action="RemoveMember" method="post" class="mb-0">
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Премахни</button>
                                </form>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
