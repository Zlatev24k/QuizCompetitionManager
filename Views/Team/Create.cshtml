@{
    ViewData["Title"] = "Създай отбор";
}

<h2 class="mb-3">Създай отбор</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Име на отбора</label>
                <input name="name" class="form-control" maxlength="80" />
            </div>

            <button type="submit" class="btn btn-primary">Създай</button>
            <a asp-controller="Home" asp-action="Competitions" class="btn btn-outline-secondary ms-2">Назад</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
