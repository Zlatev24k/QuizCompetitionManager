@model QuizCompetitionManager.Models.ViewModels.MyResultsVM
@using QuizCompetitionManager.Models

@{
    ViewData["Title"] = "Моите резултати";
}

<h2 class="mb-2">Моите резултати</h2>
<div class="text-muted mb-3">Отбор: <strong>@Model.TeamName</strong></div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Competitions.Any())
{
    <div class="alert alert-info">
        Отборът ти все още не е записан за състезания.
    </div>
}
else
{
    <div class="accordion" id="resultsAccordion">
        @for (int i = 0; i < Model.Competitions.Count; i++)
        {
            var c = Model.Competitions[i];
            var headingId = $"heading{i}";
            var collapseId = $"collapse{i}";
            var totalBadgeClass = c.Status == CompetitionStatus.Planned ? "bg-secondary" : "bg-dark";

            <div class="accordion-item">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(i == 0 ? "" : "collapsed")" type="button"
                            data-bs-toggle="collapse" data-bs-target="#@collapseId"
                            aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="@collapseId">

                        <div class="w-100 d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@c.CompetitionName</strong>
                                <span class="text-muted">• @c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                                <span class="ms-2 badge bg-secondary">@c.Status</span>
                            </div>

                            <div class="ms-3">
                                <span class="badge @totalBadgeClass">Общо: @c.TotalPoints</span>
                                @if (c.Position.HasValue)
                                {
                                    <span class="badge bg-primary ms-2">Позиция: @c.Position / @c.TeamsCount</span>
                                }
                            </div>
                        </div>
                    </button>
                </h2>

                <div id="@collapseId" class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                     aria-labelledby="@headingId" data-bs-parent="#resultsAccordion">
                    <div class="accordion-body">

                        @if (c.Status == CompetitionStatus.Planned)
                        {
                            <div class="alert alert-info mb-0">
                                Все още няма резултати за това състезание.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-striped align-middle">
                                    <thead>
                                        <tr>
                                            <th>Кръг</th>
                                            <th class="text-end">Точки</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in c.Rounds)
                                        {
                                            <tr>
                                                <td>Кръг @r.RoundNumber</td>
                                                <td class="text-end">@r.Points</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <th>Общо</th>
                                            <th class="text-end">@c.TotalPoints</th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>

                            <div class="mt-2">
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-controller="Home"
                                   asp-action="CompetitionDetails"
                                   asp-route-id="@c.CompetitionId">
                                    Виж детайли и класиране
                                </a>
                            </div>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
}
