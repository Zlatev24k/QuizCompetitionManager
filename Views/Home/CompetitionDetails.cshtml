@model QuizCompetitionManager.Models.ViewModels.CompetitionDetailsVM
@using QuizCompetitionManager.Models

@{
    ViewData["Title"] = "Детайли за състезание";
}

<section class="page-hero-small mb-4">
    <div class="page-hero-small-card">
        <h1 class="page-title mb-2">@Model.Competition.Name</h1>
        <p class="page-subtitle mb-0">
            Детайли и текущо класиране.
        </p>
    </div>
</section>

<!-- Competition Info -->
<div class="competition-details-card mb-4">
    <div class="competition-details-body">
        <div class="competition-inline-info">

            <div class="inline-item">
                <span class="inline-label">Дата и час:</span>
                <span class="inline-value">
                    @Model.Competition.StartDateTime.ToString("dd.MM.yyyy HH:mm")
                </span>
            </div>

            <div class="inline-item">
                <span class="inline-label">Брой кръгове:</span>
                <span class="inline-value">
                    @Model.Competition.RoundsCount
                </span>
            </div>

            <div class="inline-item">
                <span class="inline-label">Статус:</span>
                <span class="status-badge status-@Model.Competition.Status.ToString().ToLower()">
                    @(Model.Competition.Status == CompetitionStatus.Planned ? "Предстоящо" :
                      Model.Competition.Status == CompetitionStatus.Active ? "Активно" :
                      Model.Competition.Status == CompetitionStatus.Finished ? "Приключило" :
                      Model.Competition.Status.ToString())
                </span>
            </div>

        </div>
    </div>
</div>

<h3 class="section-title mb-3">Класиране</h3>

@if (Model.Competition.Status == CompetitionStatus.Planned)
{
    <div class="alert alert-info custom-alert">
        Все още няма резултати за това състезание.
    </div>
}
else if (!Model.Ranking.Any())
{
    <div class="alert alert-warning custom-alert">
        Няма въведени резултати.
    </div>
}
else
{
    <div class="ranking-card">
        <div class="table-responsive">
            <table class="table custom-competition-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Отбор</th>
                        <th class="text-end">Точки</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int position = 1;
                    }
                    @foreach (var row in Model.Ranking)
                    {
                        <tr class="ranking-row position-@position">
                            <td class="fw-semibold">@position</td>
                            <td>@row.TeamName</td>
                            <td class="text-end">
                                <span class="points-badge">@row.TotalPoints</span>
                            </td>
                        </tr>
                        position++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-4">
    @if (!string.IsNullOrEmpty(ViewBag.ReturnUrl))
    {
        <a class="btn btn-outline-primary action-btn" href="@ViewBag.ReturnUrl">
            ← Назад
        </a>
    }
    else
    {
        <a class="btn btn-outline-primary action-btn" asp-action="Competitions">
            ← Назад
        </a>
    }
</div>