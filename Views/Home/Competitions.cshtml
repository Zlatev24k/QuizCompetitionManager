@model QuizCompetitionManager.Models.ViewModels.PublicCompetitionsVM
@using QuizCompetitionManager.Models
@using QuizCompetitionManager.Models.ViewModels

@{
    ViewData["Title"] = "Състезания";
    var planned = Model.Competitions.Where(c => c.Status == CompetitionStatus.Planned).ToList();
    var active = Model.Competitions.Where(c => c.Status == CompetitionStatus.Active).ToList();
    var finished = Model.Competitions.Where(c => c.Status == CompetitionStatus.Finished).ToList();
}

<h2 class="mb-3">Състезания</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3">
    <!-- Planned -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Предстоящи</span>
                <span class="badge bg-secondary">@planned.Count</span>
            </div>
            <div class="card-body">
                @if (!planned.Any())
                {
                    <div class="text-muted">Няма предстоящи състезания.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Дата/час</th>
                                    <th>Кръгове</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in planned)
                                {
                                    <tr>
                                        <td>@c.Name</td>
                                        <td>@c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@c.RoundsCount</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="CompetitionDetails"
                                               asp-route-id="@c.Id">Детайли</a>

                                            @if (Model.CanJoinOrUnjoin)
                                            {
                                                var isJoined = Model.JoinedCompetitionIds.Contains(c.Id);

                                                if (!isJoined)
                                                {
                                                    <a class="btn btn-sm btn-primary ms-1"
                                                       asp-controller="Registrations"
                                                       asp-action="Join"
                                                       asp-route-competitionId="@c.Id">Запиши се</a>
                                                }
                                                else
                                                {
                                                    <form asp-controller="Registrations" asp-action="Unjoin" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="competitionId" value="@c.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Отпиши се</button>
                                                    </form>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Active -->
    <div class="col-12">
        <div class="card border-success">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold text-success">Активни</span>
                <span class="badge bg-success">@active.Count</span>
            </div>
            <div class="card-body">
                @if (!active.Any())
                {
                    <div class="text-muted">Няма активни състезания.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Дата/час</th>
                                    <th>Кръгове</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in active)
                                {
                                    <tr>
                                        <td>@c.Name</td>
                                        <td>@c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@c.RoundsCount</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="CompetitionDetails"
                                               asp-route-id="@c.Id">Детайли</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Finished -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Приключили (Архив)</span>
                <span class="badge bg-dark">@finished.Count</span>
            </div>
            <div class="card-body">
                @if (!finished.Any())
                {
                    <div class="text-muted">Няма приключили състезания.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Дата/час</th>
                                    <th>Кръгове</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in finished)
                                {
                                    <tr>
                                        <td>@c.Name</td>
                                        <td>@c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@c.RoundsCount</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="CompetitionDetails"
                                               asp-route-id="@c.Id">Детайли</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
