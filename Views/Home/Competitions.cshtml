@model QuizCompetitionManager.Models.ViewModels.PublicCompetitionsVM
@using QuizCompetitionManager.Models
@using QuizCompetitionManager.Models.ViewModels

@{
    ViewData["Title"] = "Състезания";
    var planned = Model.Competitions.Where(c => c.Status == CompetitionStatus.Planned).ToList();
    var active = Model.Competitions.Where(c => c.Status == CompetitionStatus.Active).ToList();
    var finished = Model.Competitions.Where(c => c.Status == CompetitionStatus.Finished).ToList();
}

<section class="page-hero-small mb-4">
    <div class="page-hero-small-card">
        <h1 class="page-title mb-2">Състезания</h1>
        <p class="page-subtitle mb-0">
            Разгледай предстоящите, активните и приключилите куиз състезания.
        </p>
    </div>
</section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success custom-alert" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger custom-alert" role="alert">
        @TempData["Error"]
    </div>
}

<div class="competition-sections">

    <!-- Planned -->
    <section class="competition-section-card mb-4">
        <div class="competition-section-header">
            <div>
                <h3 class="competition-section-title">Предстоящи състезания</h3>
                <p class="competition-section-text mb-0">
                    Състезания, за които може да се подготвиш и да се запишеш.
                </p>
            </div>
            <span class="competition-count-badge">@planned.Count</span>
        </div>

        <div class="competition-section-body">
            @if (!planned.Any())
            {
                <div class="empty-state-box">
                    Няма предстоящи състезания.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table custom-competition-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Име</th>
                                <th>Дата и час</th>
                                <th>Кръгове</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in planned)
                            {
                                <tr>
                                    <td class="fw-semibold">@c.Name</td>
                                    <td>@c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@c.RoundsCount</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end flex-wrap gap-2">
                                            <a class="btn btn-sm btn-outline-primary action-btn"
                                                   asp-controller="Home"
                                                   asp-action="CompetitionDetails"
                                                   asp-route-id="@c.Id">
                                                Детайли
                                            </a>

                                            @if (Model.CanJoinOrUnjoin)
                                            {
                                                var isJoined = Model.JoinedCompetitionIds.Contains(c.Id);

                                                if (!isJoined)
                                                {
                                                    <a class="btn btn-sm btn-primary action-btn"
                                                           asp-controller="Registrations"
                                                           asp-action="Join"
                                                           asp-route-competitionId="@c.Id">
                                                        Запиши се
                                                    </a>
                                                }
                                                else
                                                {
                                                    <form asp-controller="Registrations" asp-action="Unjoin" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="competitionId" value="@c.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger action-btn">
                                                            Отпиши се
                                                        </button>
                                                    </form>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <!-- Active -->
    <section class="competition-section-card mb-4 active-competition-card">
        <div class="competition-section-header">
            <div>
                <h3 class="competition-section-title active-title">Активни състезания</h3>
                <p class="competition-section-text mb-0">
                    Състезания, които се провеждат в момента.
                </p>
            </div>
            <span class="competition-count-badge active-badge">@active.Count</span>
        </div>

        <div class="competition-section-body">
            @if (!active.Any())
            {
                <div class="empty-state-box">
                    Няма активни състезания.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table custom-competition-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Име</th>
                                <th>Дата и час</th>
                                <th>Кръгове</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in active)
                            {
                                <tr>
                                    <td class="fw-semibold">@c.Name</td>
                                    <td>@c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@c.RoundsCount</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary action-btn"
                                               asp-controller="Home"
                                               asp-action="CompetitionDetails"
                                               asp-route-id="@c.Id">
                                            Детайли
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <!-- Finished -->
    <section class="competition-section-card mb-4">
        <div class="competition-section-header">
            <div>
                <h3 class="competition-section-title">Приключили състезания</h3>
                <p class="competition-section-text mb-0">
                    Архив на вече проведените състезания.
                </p>
            </div>
            <span class="competition-count-badge archive-badge">@finished.Count</span>
        </div>

        <div class="competition-section-body">
            @if (!finished.Any())
            {
                <div class="empty-state-box">
                    Няма приключили състезания.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table custom-competition-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Име</th>
                                <th>Дата и час</th>
                                <th>Кръгове</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in finished)
                            {
                                <tr>
                                    <td class="fw-semibold">@c.Name</td>
                                    <td>@c.StartDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@c.RoundsCount</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary action-btn"
                                               asp-controller="Home"
                                               asp-action="CompetitionDetails"
                                               asp-route-id="@c.Id">
                                            Детайли
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
</div>