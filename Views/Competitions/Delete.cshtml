@model QuizCompetitionManager.Models.Competition
@using QuizCompetitionManager.Models

@{
    ViewData["Title"] = "Изтриване";

    var statusText = Model.Status == CompetitionStatus.Planned ? "Предстоящо"
        : Model.Status == CompetitionStatus.Active ? "Активно"
        : Model.Status == CompetitionStatus.Finished ? "Приключило"
        : Model.Status.ToString();
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
            <div class="page-hero-small-card danger-hero">
                <h1 class="page-title mb-2 text-danger">Изтриване на състезание</h1>
                <p class="page-subtitle mb-0">
                    Това действие е необратимо. Увери се, че наистина искаш да изтриеш състезанието.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">

        <div class="delete-warning-box mb-4">
            ⚠️ Сигурен ли си, че искаш да изтриеш това състезание?
        </div>

        <div class="competition-details-card mb-4">
            <div class="competition-details-body">

                <div class="mb-3">
                    <h3 class="manage-summary-title mb-1">@Model.Name</h3>
                </div>

                <div class="competition-inline-info">
                    <div class="inline-item">
                        <span class="inline-label">Дата и час:</span>
                        <span class="inline-value">@Model.StartDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <div class="inline-item">
                        <span class="inline-label">Брой кръгове:</span>
                        <span class="inline-value">@Model.RoundsCount</span>
                    </div>

                    <div class="inline-item">
                        <span class="inline-label">Статус:</span>
                        <span class="status-badge status-@Model.Status.ToString().ToLower()">
                            @statusText
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-danger form-action-btn">
                    Да, изтрий
                </button>

                <a asp-action="Index" class="btn btn-outline-primary form-action-btn">
                    Отказ
                </a>
            </div>
        </form>

    </div>
</div>