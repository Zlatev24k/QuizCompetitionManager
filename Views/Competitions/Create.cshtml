@model QuizCompetitionManager.Models.Competition
@using QuizCompetitionManager.Models

@{
    ViewData["Title"] = "Ново състезание";
}

<section class="page-hero-small mb-4">
    <div class="page-hero-small-card">
        <h1 class="page-title mb-2">Ново състезание</h1>
        <p class="page-subtitle mb-0">
            Създай ново куиз състезание, като попълниш основната информация.
        </p>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div class="form-page-card">
            <form asp-action="Create" method="post" id="competitionForm" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary-custom mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label custom-label">Име</label>
                    <input asp-for="Name"
                           class="form-control custom-input"
                           id="competitionName" />
                    <span asp-validation-for="Name" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StartDateTime" class="form-label custom-label">Дата и час</label>
                    <input asp-for="StartDateTime"
                           id="startDateTime"
                           type="text"
                           class="form-control custom-input" />
                    <span asp-validation-for="StartDateTime" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RoundsCount" class="form-label custom-label">Брой кръгове</label>
                    <input asp-for="RoundsCount"
                           class="form-control custom-input"
                           id="roundsCount"
                           type="number"
                           min="1"
                           step="1" />
                    <span asp-validation-for="RoundsCount" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Status" class="form-label custom-label">Статус</label>
                    <select asp-for="Status"
                            id="statusSelect"
                            class="form-select custom-input"
                            asp-items="Html.GetEnumSelectList<CompetitionStatus>()">
                    </select>
                    <span asp-validation-for="Status" class="text-danger field-validation-custom"></span>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary form-action-btn">
                        Запази
                    </button>
                    <a asp-action="Index" class="btn btn-outline-primary form-action-btn">
                        Назад
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function getStatusText(value) {
            if (value === "0") return "Предстоящо";
            if (value === "1") return "Активно";
            if (value === "2") return "Приключило";
            return "";
        }

        function updateDateRestriction() {
            const status = document.getElementById("statusSelect");
            const dateInput = document.getElementById("startDateTime");

            if (!status || !dateInput || !dateInput._flatpickr) return;

            const now = new Date();

            if (status.value === "2") {
                dateInput._flatpickr.set("minDate", null);
            } else {
                dateInput._flatpickr.set("minDate", now);
            }
        }

        function setBulgarianValidationMessage(el) {
            if (el.validity.valueMissing) {
                if (el.id === "competitionName") {
                    el.setCustomValidity("Моля, въведете име на състезанието.");
                } else if (el.id === "startDateTime") {
                    el.setCustomValidity("Моля, въведете дата и час.");
                } else if (el.id === "roundsCount") {
                    el.setCustomValidity("Моля, въведете брой кръгове.");
                } else {
                    el.setCustomValidity("Моля, попълнете това поле.");
                }
            } else if (el.validity.rangeUnderflow) {
                if (el.id === "startDateTime") {
                    el.setCustomValidity("Моля, въведете дата и час, които са след текущите.");
                } else if (el.id === "roundsCount") {
                    el.setCustomValidity("Броят кръгове трябва да бъде поне 1.");
                } else {
                    el.setCustomValidity("Стойността е твърде малка.");
                }
            } else if (el.validity.rangeOverflow) {
                el.setCustomValidity("Стойността е твърде голяма.");
            } else if (el.validity.stepMismatch) {
                if (el.id === "roundsCount") {
                    el.setCustomValidity("Моля, въведете цяло число за брой кръгове.");
                } else {
                    el.setCustomValidity("Моля, въведете валидна стойност.");
                }
            } else if (el.validity.badInput) {
                el.setCustomValidity("Моля, въведете валидна стойност.");
            } else {
                el.setCustomValidity("");
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const dateInput = document.getElementById("startDateTime");
            const statusSelect = document.getElementById("statusSelect");
            const form = document.getElementById("competitionForm");

            flatpickr("#startDateTime", {
                enableTime: true,
                dateFormat: "Y-m-d H:i",
                time_24hr: true,
                locale: "bg",
                disableMobile: true
            });

            updateDateRestriction();
            statusSelect?.addEventListener("change", updateDateRestriction);

            const allInputs = form.querySelectorAll("input, select");

            allInputs.forEach(el => {
                el.addEventListener("invalid", function () {
                    setBulgarianValidationMessage(this);
                });

                el.addEventListener("input", function () {
                    this.setCustomValidity("");
                });

                el.addEventListener("change", function () {
                    this.setCustomValidity("");
                });
            });

            form.addEventListener("submit", function () {
                allInputs.forEach(el => el.setCustomValidity(""));
            });
        });
    </script>
}