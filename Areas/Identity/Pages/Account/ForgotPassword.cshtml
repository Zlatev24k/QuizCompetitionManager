@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Забравена парола";
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="page-hero-small-card text-center">
                <h1 class="page-title mb-2">Забравена парола</h1>
                <p class="page-subtitle mb-0">
                    Въведи своя имейл адрес, за да получиш инструкции за смяна на паролата.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-page-card auth-card">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary-custom mb-3" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label custom-label">Имейл</label>
                    <input asp-for="Input.Email"
                           class="form-control custom-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="example@email.com" />
                    <span asp-validation-for="Input.Email" class="text-danger field-validation-custom"></span>
                </div>

                <button type="submit" class="w-100 btn btn-primary form-action-btn auth-submit-btn">
                    Изпрати инструкции
                </button>

                <div class="auth-links mt-4">
                    <p class="mb-0">
                        <a asp-page="./Login">Обратно към вход</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}