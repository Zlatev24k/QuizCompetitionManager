@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="page-hero-small-card text-center">
                <h1 class="page-title mb-2">Регистрация</h1>
                <p class="page-subtitle mb-0">
                    Създай нов акаунт, за да участваш в състезания и да управляваш своя отбор.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-page-card auth-card">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary-custom mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label custom-label">Имейл</label>
                    <input asp-for="Input.Email"
                           class="form-control custom-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="example@email.com" />
                    <span asp-validation-for="Input.Email" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label custom-label">Парола</label>
                    <input asp-for="Input.Password"
                           class="form-control custom-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Въведи парола" />
                    <span asp-validation-for="Input.Password" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label custom-label">Потвърди парола</label>
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control custom-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Повтори паролата" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger field-validation-custom"></span>
                </div>

                <button id="registerSubmit" type="submit" class="w-100 btn btn-primary form-action-btn auth-submit-btn">
                    Регистрация
                </button>

                <div class="auth-links mt-4">
                    <p class="mb-0">
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                            Вече имаш акаунт? Влез оттук
                        </a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}