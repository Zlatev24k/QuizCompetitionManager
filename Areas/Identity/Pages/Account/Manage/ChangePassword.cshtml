@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Смяна на парола";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="page-hero-small-card text-center">
                <h1 class="page-title mb-2">Смяна на парола</h1>
                <p class="page-subtitle mb-0">
                    Обнови паролата на своя акаунт.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="form-page-card auth-card">
            <form id="change-password-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary-custom mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.OldPassword" class="form-label custom-label">Текуща парола</label>
                    <input asp-for="Input.OldPassword"
                           class="form-control custom-input"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="Въведи текущата парола" />
                    <span asp-validation-for="Input.OldPassword" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.NewPassword" class="form-label custom-label">Нова парола</label>
                    <input asp-for="Input.NewPassword"
                           class="form-control custom-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Въведи нова парола" />
                    <span asp-validation-for="Input.NewPassword" class="text-danger field-validation-custom"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label custom-label">Потвърди новата парола</label>
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control custom-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Повтори новата парола" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger field-validation-custom"></span>
                </div>

                <button type="submit" class="w-100 btn btn-primary form-action-btn auth-submit-btn">
                    Запази новата парола
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}