@page
@model IndexModel

@{
    ViewData["Title"] = "Профил";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="page-hero-small-card text-center">
                <h1 class="page-title mb-2">Профил</h1>
                <p class="page-subtitle mb-0">
                    Прегледай и редактирай информацията за своя акаунт.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="form-page-card auth-card">
            <form id="profile-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary-custom mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label custom-label">Потребителско име</label>
                    <input asp-for="Username"
                           class="form-control custom-input"
                           placeholder="Потребителско име"
                           disabled />
                </div>

                <div class="mb-4">
                    <label asp-for="Input.PhoneNumber" class="form-label custom-label">Телефонен номер</label>
                    <input asp-for="Input.PhoneNumber"
                           class="form-control custom-input"
                           placeholder="Въведи телефонен номер" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger field-validation-custom"></span>
                </div>

                <button id="update-profile-button" type="submit" class="w-100 btn btn-primary form-action-btn auth-submit-btn">
                    Запази
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}