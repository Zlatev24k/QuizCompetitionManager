@page
@model PersonalDataModel

@{
    ViewData["Title"] = "Лични данни";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="page-hero-small-card text-center">
                <h1 class="page-title mb-2">Лични данни</h1>
                <p class="page-subtitle mb-0">
                    Управлявай личните си данни или изтрий своя акаунт.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="form-page-card">

            <div class="mb-4">
                <p class="mb-2">
                    Твоят акаунт съдържа лични данни, които си предоставил в системата.
                </p>
                <p class="mb-0">
                    Можеш да изтеглиш тези данни или да изтриеш своя акаунт.
                </p>
            </div>

            <div class="mb-4">
                <form id="download-data" asp-page="DownloadPersonalData" method="post">
                    <button class="btn btn-outline-primary form-action-btn w-100" type="submit">
                        Изтегли данните
                    </button>
                </form>
            </div>

            <div class="delete-warning-box mb-3 text-center">
                ⚠️ Изтриването на акаунта е необратимо.
            </div>

            <a id="delete"
                   asp-page="DeletePersonalData"
                   class="btn btn-danger form-action-btn w-100">
                Изтрий акаунта
            </a>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}