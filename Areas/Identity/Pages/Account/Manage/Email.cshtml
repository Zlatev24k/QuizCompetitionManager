@page
@model EmailModel

@{
    ViewData["Title"] = "Имейл";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<section class="page-hero-small mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="page-hero-small-card text-center">
                <h1 class="page-title mb-2">Имейл</h1>
                <p class="page-subtitle mb-0">
                    Управлявай своя имейл адрес и потвърждението му.
                </p>
            </div>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="form-page-card auth-card">
            <form id="email-form" method="post">
                <div asp-validation-summary="All" class="text-danger validation-summary-custom mb-3" role="alert"></div>

                <!-- Current email -->
                @if (Model.IsEmailConfirmed)
                {
                    <div class="mb-3">
                        <label class="form-label custom-label">Текущ имейл</label>
                        <div class="input-group">
                            <input asp-for="Email"
                                   class="form-control custom-input"
                                   disabled />
                            <span class="input-group-text text-success fw-bold">✓</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label custom-label">Текущ имейл</label>
                        <input asp-for="Email"
                               class="form-control custom-input mb-2"
                               disabled />
                    </div>
                }

                <!-- New email -->
                <div class="mb-4">
                    <label asp-for="Input.NewEmail" class="form-label custom-label">Нов имейл</label>
                    <input asp-for="Input.NewEmail"
                           class="form-control custom-input"
                           autocomplete="email"
                           aria-required="true"
                           placeholder="example@email.com" />
                    <span asp-validation-for="Input.NewEmail" class="text-danger field-validation-custom"></span>
                </div>

                <button id="change-email-button"
                        type="submit"
                        asp-page-handler="ChangeEmail"
                        class="w-100 btn btn-primary form-action-btn auth-submit-btn">
                    Смени имейла
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}